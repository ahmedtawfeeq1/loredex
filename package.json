{
  "name": "loredex",
  "version": "2.3.1",
  "description": "Universal control system for coding agents: shared memory, cross-project handoffs, research management, and MCP + Obsidian dashboards across products and repos.",
  "type": "module",
  "license": "MIT",
  "author": "Ahmed Tawfeeq",
  "bin": {
    "loredex": "dist/cli.js"
  },
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "tsup": {
    "entry": [
      "src/cli.ts",
      "src/lib.ts"
    ],
    "format": [
      "esm"
    ],
    "target": "node20",
    "dts": {
      "entry": "src/lib.ts",
      "compilerOptions": {
        "ignoreDeprecations": "6.0"
      }
    },
    "clean": true
  },
  "keywords": [
    "obsidian",
    "markdown",
    "ai",
    "claude-code",
    "codex",
    "cursor",
    "knowledge-base",
    "vault",
    "second-brain",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedtawfeeq1/loredex.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
